# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="AI"

# PINECONE_API_KEY: Required for Pinecone vector database.
PINECONE_API_KEY="pcs"

# PINECONE_INDEX: The name of your Pinecone index.
PINECONE_INDEX="voicememos"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# STORAGE_DIR: Directory for persistent audio recording storage.
# On HF Spaces this is /data/recordings (set in Dockerfile).
# Locally, defaults to ./uploads if not set.
# STORAGE_DIR="./uploads"
