# ══════════════════════════════════════════════════════════════════════
# VoiceInsight AI — Environment Configuration Template
# ══════════════════════════════════════════════════════════════════════

# ── API Keys (REQUIRED) ─────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_INDEX="voicememos"
HF_TOKEN="your-huggingface-token" # Required to download Gemma 4 local models

# ── LLM Configuration ───────────────────────────────────────────────
LLM_PROVIDER="gemini" # gemini | litert | groq | openai
GEMINI_MODEL="gemini-2.5-flash"
LITERT_MODEL_PATH="./models/gemma-4-e2b.litertlm" # Path to local Gemma 4 model

# ── Whisper Configuration ───────────────────────────────────────────
WHISPER_MODEL="large-v3-turbo"
WHISPER_DEVICE="cpu"
WHISPER_COMPUTE_TYPE="int8"

# ── Database ────────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://voiceinsight:voiceinsight@localhost:5432/voiceinsight"

# ── Redis / Celery ──────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://redis:6379/1"

# ── Storage ─────────────────────────────────────────────────────────
STORAGE_DIR="./data"
RAW_AUDIO_DIR="./data/raw"
SNIPPETS_DIR="./data/snippets"

# ── S3 Object Storage (Production) ──────────────────────────────────
S3_BUCKET_NAME=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="auto"
S3_ENDPOINT_URL=""

# ── Optional LLM Providers (add keys to activate) ──────────────────
# GROQ_API_KEY=""
# OPENAI_API_KEY=""
# DEEPSEEK_API_KEY=""
