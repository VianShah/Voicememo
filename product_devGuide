All decoded via `AudioContext.decodeAudioData()` — browser handles codec detection natively.

#### Step 1.4 — DSP Pipeline + lamejs MP3 Encoding

Existing DSP pipeline from `audioUtils.ts` stays the same. **Add** `lamejs` for MP3 export:

```typescript
// mp3Encoder.ts
import lamejs from 'lamejs';

export function encodeToMp3(audioBuffer: AudioBuffer): Blob {
  const mp3encoder = new lamejs.Mp3Encoder(1, audioBuffer.sampleRate, 128);
  const samples = audioBuffer.getChannelData(0);
  const sampleBlockSize = 1152;
  const mp3Data: Int8Array[] = [];
  
  for (let i = 0; i < samples.length; i += sampleBlockSize) {
    const chunk = samples.subarray(i, i + sampleBlockSize);
    const int16 = new Int16Array(chunk.length);
    for (let j = 0; j < chunk.length; j++) {
      int16[j] = Math.max(-32768, Math.min(32767, chunk[j] * 32768));
    }
    const mp3buf = mp3encoder.encodeBuffer(int16);
    if (mp3buf.length > 0) mp3Data.push(new Int8Array(mp3buf));
  }
  
  const end = mp3encoder.flush();
  if (end.length > 0) mp3Data.push(new Int8Array(end));
  
  return new Blob(mp3Data, { type: 'audio/mpeg' });
}
```

> [!NOTE]
> **FFmpeg (server-side) vs lamejs (client-side):**
> | | lamejs (Client) | FFmpeg (Express) |
> |---|---|---|
> | **Speed** | Slower (~1x real-time on mobile) | Faster (native C, ~10x real-time) |
> | **Cost** | Free — runs in browser | Requires server CPU time |
> | **Formats** | MP3 only | Any format (MP3, M4A, FLAC, OGG...) |
> | **File size limit** | ~10-15 min comfortable | Handles hours |
> | **Phase 1 verdict** | ✅ Use for normal recordings (<45 min) | Future — add if client-side is too slow |
>
> **Decision**: Start with `lamejs` client-side. If performance is poor on mobile for long recordings, add FFmpeg to the Express service later.

#### Step 1.5 — Vercel AI SDK + Gemini Integration

Replace Google SDK with Vercel AI SDK in Next.js API routes:

```typescript
// web/src/app/api/analyze/route.ts
import { generateText, embed } from "ai";
import { google } from "@ai-sdk/google";

export async function POST(req: Request) {
  const { audioBase64, mimeType } = await req.json();

  // 1. Analyze with Gemini (multimodal)
  const { text } = await generateText({
    model: google("gemini-2.5-flash"),
    messages: [{
      role: "user",
      content: [
        { type: "text", text: ANALYSIS_PROMPT },
        { type: "file", data: audioBase64, mimeType },
      ],
    }],
  });

  const analysis = JSON.parse(text);

  // 2. Generate embedding
  const { embedding } = await embed({
    model: google.textEmbeddingModel("text-multilingual-embedding-002"),
    value: analysis.transcript,
  });

  // 3. Upsert to Pinecone (with tags in metadata)
  await pineconeIndex.upsert([{
    id: crypto.randomUUID(),
    values: embedding,
    metadata: {
      title: analysis.title,
      summary: analysis.summary,
      transcript: analysis.transcript,
      tags: analysis.tags,           // ← tags in metadata
      timestamp: Date.now(),
    },
  }]);

  return Response.json({ ...analysis, id });
}
```

#### Step 1.6 — PWA + File System Access API

```typescript
// fileSystem.ts
export async function saveAudioToDevice(blob: Blob, filename: string) {
  try {
    // Modern File System Access API
    const handle = await window.showSaveFilePicker({
      suggestedName: filename,
      types: [{
        description: 'Audio Files',
        accept: {
          'audio/mpeg': ['.mp3'],
          'audio/wav': ['.wav'],
          'audio/mp4': ['.m4a'],
        },
      }],
    });
    const writable = await handle.createWritable();
    await writable.write(blob);
    await writable.close();
    return true;
  } catch (err) {
    // Fallback: download link
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = filename;
    a.click();
    URL.revokeObjectURL(url);
    return false;
  }
}
```

